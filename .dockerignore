.git
.gitignore

# GitHub Actions workflows (niso del aplikacije)
.github

# Docker datoteke same po sebi
Dockerfile
.dockerignore

# Testne datoteke (ne sodijo v produkcijsko sliko)
tests/

# Začasne datoteke in logi
*.log
napaka.txt

# OS specifične datoteke
.DS_Store
Thumbs.db
